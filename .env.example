# ──────────────────────────────────────────────
#  Environment variable template
#  Copy this file to .env and fill in the values
#  $ cp .env.example .env
# ──────────────────────────────────────────────


# Port this service listens on
PORT=9099

# Backend API base URL
ATTENDANCE_API_URL=
# API Keys
ATTENDANCE_API_KEY=

# Org & activity config
PARENT_ORG_ID=2
ACTIVITY_ID=4

# WhatsApp recipients
WHATSAPP_TO_1=
WHATSAPP_TO_2=

# Email (Nodemailer + Gmail)
EMAIL_FROM=
EMAIL_APP_PASSWORD=
EMAIL_TO_1=
EMAIL_TO_2=
EMAIL_TO_3=
EMAIL_TO_4=

# For choreo
# GitHub Personal Access Token (for triggering workflows via init.js)
GITHUB_ACCESS_TOKEN=